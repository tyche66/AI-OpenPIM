# Database
# All values below are EXAMPLE PLACEHOLDERS. Replace them in /etc/ai-pim/*.env
# (mode 0600, never committed) on the production host. The repo's .env file is
# in .gitignore and MUST NOT contain real secrets.
POSTGRES_PASSWORD=__REPLACE_ME_WITH_A_STRONG_PASSWORD__
POSTGRES_USER=pim
POSTGRES_DB=ai_pim
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
UVICORN_WORKERS=2

# Build metadata. Inject the same values into the frontend Vite build.
APP_VERSION=dev
BUILD_ID=dev-local
GIT_COMMIT=unknown
BUILD_TIME=unknown
APP_ENV=production
VITE_APP_VERSION=dev
VITE_BUILD_ID=dev-local
VITE_GIT_COMMIT=unknown
VITE_BUILD_TIME=unknown
# Integration test DB (postgres initdb creates ai_pim_test on first start).
# If the test DB name does NOT carry a "test" marker, set AI_PIM_TEST_DB_APPROVED=1.
TEST_DATABASE_URL=postgresql+asyncpg://pim:__REPLACE_ME__@localhost:5432/ai_pim_test

# JWT
JWT_SECRET=__REPLACE_ME_WITH_A_LONG_RANDOM_JWT_SECRET__
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
ADMIN_USERNAME=admin
ADMIN_PASSWORD=__REPLACE_ME_WITH_A_STRONG_ADMIN_PASSWORD__

# MinIO
MINIO_ROOT_USER=__REPLACE_ME_MINIO_USER__
MINIO_ROOT_PASSWORD=__REPLACE_ME_WITH_A_STRONG_MINIO_PASSWORD__

# AI — V1.2 default fail-closed (docs/v1.2-plan.md §6.5):
# Real AI keys MUST NEVER be committed to Git, logs, command args or artifacts.
# Supply AI_API_KEY via the on-host env file (mode 0600) only.
AI_ADAPTER=none
AI_API_URL=
AI_API_KEY=

# Local OCR compensation (none or tesseract)
OCR_ADAPTER=none
OCR_API_URL=http://ocr:8080
OCR_TIMEOUT=300
