# AI-PIM V1.2 backup environment file — EXAMPLE.
# Copy to /etc/ai-pim/backup.env on the host and CHMOD 0600.
# NEVER commit real values to the repo. Kept in scripts/ as a template for
# operators; does not contain any secrets.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pim
POSTGRES_DB=ai_pim
POSTGRES_PASSWORD=__REPLACE_ME__

MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=__REPLACE_ME__
MINIO_ROOT_PASSWORD=__REPLACE_ME__
MINIO_BUCKET=ai-pim-files

BACKUP_DIR=/var/backups/ai-pim
KEEP=7
BACKUP_MIN_FREE_BYTES=5368709120
