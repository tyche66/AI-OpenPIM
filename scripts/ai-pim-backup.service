[Unit]
Description=AI-PIM V1.2 daily backup (PostgreSQL + MinIO, shared batch)
Documentation=file:///opt/AI-OpenPIM/docs/v1.2-plan.md
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
WorkingDirectory=/opt/AI-OpenPIM
EnvironmentFile=/etc/ai-pim/backup.env
ExecStart=/opt/AI-OpenPIM/scripts/backup.sh
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
StandardOutput=append:/var/log/ai-pim/backup.log
StandardError=append:/var/log/ai-pim/backup.err
